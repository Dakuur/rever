# ══════════════════════════════════════════════════════════════════════════════
#  REVER – Environment Variables
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── Gemini AI ─────────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Firebase ──────────────────────────────────────────────────────────────────
# Get from: Firebase Console → Project Settings → Your apps → Web app
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=000000000000
FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx

# ── Shopify Partner App ───────────────────────────────────────────────────────
# Get from: Shopify Partners → Apps → Your app → API credentials
SHOPIFY_CLIENT_ID=your_shopify_client_id
SHOPIFY_CLIENT_SECRET=your_shopify_client_secret
SHOPIFY_STORE_DOMAIN=yourstore.myshopify.com

# ── Shopify Storefront API ────────────────────────────────────────────────────
# Get from: Shopify Admin → Settings → Apps and sales channels → Develop apps
#           → Your app → API credentials → Storefront API access token
SHOPIFY_STOREFRONT_PUBLIC_TOKEN=your_storefront_public_token
SHOPIFY_STOREFRONT_PRIVATE_TOKEN=your_storefront_private_token
