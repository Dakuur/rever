rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Conversations: owner can read/write; anonymous sessions allowed
    match /conversations/{convId} {
      allow create: if true;  // anyone can start a conversation
      allow read, update: if request.auth == null
        || resource.data.userId == request.auth.uid
        || resource.data.userId == 'anonymous';

      match /messages/{msgId} {
        allow read, write: if true;  // simplified for widget embed
      }
    }

    // Return requests: write-only for clients, read requires auth
    match /return_requests/{reqId} {
      allow create: if true;   // any visitor can submit a return
      allow read: if request.auth != null;  // only authenticated users can read
      allow update, delete: if false;       // immutable once created
    }
  }
}
